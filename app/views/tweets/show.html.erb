<div class="container mt-3">
  <%= cl_image_tag @tweet.photo.key, height: 300, width: 400, crop: :fill %>
  <strong>Tweet (<%= @tweet.shortened.size %>):</strong>
  <blockquote class="blockquote"><%= @tweet.shortened %></blockquote>

  <strong>Original:</strong>
  <%= simple_format @tweet.long %>
</div>
